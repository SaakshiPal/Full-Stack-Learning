🔷 Basic API Example

```javascript
const http = require("http");

http.createServer((req, res) => {
  if (req.url === "/api") {
    res.write(JSON.stringify({ message: "Hello API" }));
  } else {
    res.write("Home Page");
  }
  res.end();
}).listen(3000);
```

